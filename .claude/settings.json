{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test*)",
      "Bash(npm run build)",
      "Bash(npm start)",
      "Bash(npm install*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push origin main)",
      "Bash(gh issue*)",
      "Bash(gh pr*)",
      "Bash(python3*)",
      "Bash(pip*)",
      "Bash(uvicorn*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(DROP TABLE*)",
      "Bash(git push origin --delete*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/file-protection.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lint-on-save.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-commit.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/finish-notify.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-deploy.sh",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": true
}
